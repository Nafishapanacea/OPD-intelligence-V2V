# OPD Intelligence V2V - Production Configuration Template
# Copy this file to .env and fill in your values

# ============ GEMINI API ============
GEMINI_API_KEY=your_gemini_api_key_here

# ============ DATABASE (PostgreSQL) ============
# Format: postgresql+asyncpg://username:password@host:port/database
# Create database first: createdb opd_assistant
DATABASE_URL=postgresql+asyncpg://postgres:your_password@localhost:5432/opd_assistant

# Connection pooling settings
DB_POOL_MIN=10
DB_POOL_MAX=20
DB_POOL_TIMEOUT_S=30
DB_COMMAND_TIMEOUT_S=10

# ============ REDIS ============
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_MAX_CONNECTIONS=50

# ============ TTS WORKERS ============
# Max concurrent OmniVoice inference tasks (limited by VRAM: 24GB ÷ 4.9GB ≈ 5)
TTS_MAX_WORKERS=5

# TTS inference timeout (seconds) - allows 2-3s inference + overhead
TTS_WORKER_TIMEOUT_S=30

# TTS queue max depth - reject requests if queue exceeds this
TTS_QUEUE_MAX_DEPTH=1000

# ============ GEMINI API TUNING ============
# Timeout for Gemini API calls (seconds)
GEMINI_TIMEOUT_S=15

# Retry settings
GEMINI_MAX_RETRIES=3
GEMINI_RETRY_DELAY_MS=100

# ============ FASTAPI ============
PORT=8002
HOST=0.0.0.0
WORKERS=1
RELOAD=False

# ============ CORS ============
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# ============ LOGGING ============
LOG_LEVEL=INFO

# ============ APPLICATION ============
# TTS Reference audio files (required for OmniVoice)
# Download from: https://github.com/NVIDIA/OpenVoiceOS/releases
# Or use any .mp3/.wav files with native speaker samples
TTS_REFERENCE_ENGLISH=/path/to/eng_ref.mp3
TTS_REFERENCE_HINDI=/path/to/hindi_ref.mp3
TTS_REFERENCE_MARATHI=/path/to/marathi_ref.wav

